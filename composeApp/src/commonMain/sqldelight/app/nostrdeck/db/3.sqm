-- Migration v3 -> v4.
--
-- Adds `used_hashtag`: hashtags the user has posted, for compose-time
-- recommendations (prefix match + last-5 one-tap). Mirrors Nostr.sq.
-- Adding this 3.sqm makes NostrDb.Schema.version == 4.

CREATE TABLE IF NOT EXISTS used_hashtag (
    tag       TEXT NOT NULL PRIMARY KEY,
    last_used INTEGER NOT NULL,
    uses      INTEGER NOT NULL DEFAULT 1
);
